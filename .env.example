# ============================================================================
# TurnosBarbería — variables de entorno
# ============================================================================
# Las vars NEXT_PUBLIC_* se exponen al cliente. El resto son server-only.
# Copiá este archivo a .env.local para desarrollo y configurá las mismas en
# Vercel → Project → Settings → Environment Variables para producción.
# ============================================================================

# ─── Supabase ──────────────────────────────────────────────────────────────
# Project del cliente. Cliente Supabase + admin client.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Site URL ──────────────────────────────────────────────────────────────
# OBLIGATORIA en prod. Sin esto MP rechaza preferencias porque back_urls y
# notification_url caen a localhost. Si está vacío, magic links de email y
# webhooks de pago se rompen en producción.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Emails (Resend) ───────────────────────────────────────────────────────
# Sin RESEND_API_KEY los mails se skipean silenciosamente (warning en log,
# no crash). EMAIL_FROM default es onboarding@resend.dev que solo permite
# mandar al owner de la cuenta de Resend — para clientes reales hay que
# verificar un dominio propio.
RESEND_API_KEY=re_...
EMAIL_FROM="TurnosBarbería <notificaciones@tudominio.com>"

# ─── Super-admin (/desarrollo) ─────────────────────────────────────────────
# OBLIGATORIA: si falta, no se puede entrar a /desarrollo/login y por ende
# no se pueden aprobar shops nuevos ni resetear passwords de owners.
SUPER_ADMIN_EMAIL=info@didigitalstudio.com
SUPER_ADMIN_PASSWORD=
# Secret HMAC para firmar la cookie de sesión super-admin. Si falta, se
# reusa CRON_SECRET. Recomendado: generar uno aparte con `openssl rand -hex 32`.
SUPER_ADMIN_SECRET=

# ─── Cron ──────────────────────────────────────────────────────────────────
# Auth Bearer para /api/cron/reminders (lo llama Vercel Cron). Sin esto
# nadie puede invocar el cron y los recordatorios no se mandan.
CRON_SECRET=

# ─── Google Maps (opcional) ────────────────────────────────────────────────
# Si está configurada, la pantalla de confirmación de turno muestra un mapa
# embed con la dirección del shop. Sin ella, fallback a un link "Cómo llegar"
# que abre Google Maps en nueva pestaña.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ─── Facturación (opcional) ────────────────────────────────────────────────
# Override de la URL base de TusFacturasAPP. Default OK para producción.
TUSFACTURAS_API_BASE=

# ─── Notificaciones internas (opcional) ────────────────────────────────────
# Webhook al panel di-admin cuando se crea un shop nuevo.
DI_ADMIN_WEBHOOK_URL=
DI_ADMIN_WEBHOOK_SECRET=
